# =====================================
# QS Blog - License & Payment System
# =====================================
# 复制此文件为 .env，并填入你的配置信息

# ── 基础配置 ──
PORT=8080
ADMIN_KEY=your-secure-admin-key-here
BASE_URL=http://142.93.127.127

# ── Stripe 配置 ──
# 在 https://dashboard.stripe.com/apikeys 获取
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Webhook Secret：在 Stripe Dashboard → Developers → Webhooks → 添加端点后获取
# 端点 URL：http://142.93.127.127/api/v1/webhook/stripe
# 选择事件：checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── 邮件配置 ──
# 推荐使用 QQ 邮箱、Gmail 或 SendGrid
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your-smtp-password-or-app-specific-password
FROM_EMAIL=your_email@qq.com
FROM_NAME=QS Blog

# ── 数据库 & 日志 ──
DB_PATH=/data/activate.db
LOG_PATH=/var/log/activity.log
LOG_MAX_AGE_DAYS=30
